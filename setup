#!/bin/bash

set -euo pipefail

readonly DIRS=("$HOME/.config" "$HOME/.config/nixpkgs" "$HOME/.zsh" "$HOME/.local/bin" "$HOME/.zfunc" "$HOME/.krew/bin")

log() { printf '[%s] [%s] %s\n' "$(date +%T)" "$1" "$2"; }

install_vault() {
    local version
    version=$(curl -sS "https://api.github.com/repos/hashicorp/vault/releases/latest" | grep -o '"tag_name": ".*"' | cut -d'"' -f4)
    log INFO "Installing Vault ${version}"
    
    local tmpdir
    tmpdir=$(mktemp -d)
    (
        cd "$tmpdir"
        log INFO "Downloading Vault from: https://releases.hashicorp.com/vault/${version#v}/vault_${version#v}_linux_arm64.zip"
        curl -sSLO "https://releases.hashicorp.com/vault/${version#v}/vault_${version#v}_linux_arm64.zip"
        unzip -q "vault_${version#v}_linux_arm64.zip"
        chmod +x vault
        mv vault "$HOME/.local/bin/vault"
    )
    rm -rf "$tmpdir"
}

install_velero() {
    local version
    version=$(curl -sS "https://api.github.com/repos/vmware-tanzu/velero/releases/latest" | grep -o '"tag_name": ".*"' | cut -d'"' -f4)
    log INFO "Installing Velero ${version}"
    
    local tmpdir
    tmpdir=$(mktemp -d)
    (
        cd "$tmpdir"
        local url="https://github.com/vmware-tanzu/velero/releases/download/${version}/velero-v${version#v}-linux-arm64.tar.gz"
        log INFO "Downloading Velero from: ${url}"
        
        if ! curl -fsSL "$url" -o velero.tar.gz; then
            log ERROR "Failed to download Velero"
            return 1
        fi
        
        tar xzf velero.tar.gz
        cd velero-v*
        chmod +x velero
        mv velero "$HOME/.local/bin/velero"
        
        if "$HOME/.local/bin/velero" version >/dev/null 2>&1; then
            log INFO "Successfully installed Velero ${version}"
        else
            log ERROR "Failed to verify Velero installation"
            return 1
        fi
    )
    rm -rf "$tmpdir"
}

install_pluto() {
    local version
    version=$(curl -sS "https://api.github.com/repos/FairwindsOps/pluto/releases/latest" | grep -o '"tag_name": ".*"' | cut -d'"' -f4)
    log INFO "Installing Pluto ${version}"
    
    local tmpdir
    tmpdir=$(mktemp -d)
    (
        cd "$tmpdir"
        local url="https://github.com/FairwindsOps/pluto/releases/download/${version}/pluto_${version#v}_linux_arm64.tar.gz"
        log INFO "Downloading Pluto from: ${url}"
        
        if ! curl -fsSL "$url" -o pluto.tar.gz; then
            log ERROR "Failed to download Pluto"
            return 1
        fi
        
        tar xzf pluto.tar.gz
        chmod +x pluto
        mv pluto "$HOME/.local/bin/pluto"
        
        if "$HOME/.local/bin/pluto" version >/dev/null 2>&1; then
            log INFO "Successfully installed Pluto ${version}"
        else
            log ERROR "Failed to verify Pluto installation"
            return 1
        fi
    )
    rm -rf "$tmpdir"
}

install_argocd() {
    local version
    version=$(curl -sS "https://api.github.com/repos/argoproj/argo-cd/releases/latest" | grep -o '"tag_name": ".*"' | cut -d'"' -f4)
    log INFO "Installing ArgoCD CLI ${version}"
    curl -sSL -o "$HOME/.local/bin/argocd" "https://github.com/argoproj/argo-cd/releases/download/${version}/argocd-linux-arm64"
    chmod +x "$HOME/.local/bin/argocd"
}

install_argo() {
    local version
    version=$(curl -sS "https://api.github.com/repos/argoproj/argo-workflows/releases/latest" | grep -o '"tag_name": ".*"' | cut -d'"' -f4)
    log INFO "Installing Argo Workflows CLI ${version}"
    
    local tmpdir
    tmpdir=$(mktemp -d)
    (
        cd "$tmpdir"
        curl -sSL "https://github.com/argoproj/argo-workflows/releases/download/${version}/argo-linux-arm64.gz" -o argo.gz
        gunzip argo.gz
        chmod +x argo
        mv argo "$HOME/.local/bin/argo"
    )
    rm -rf "$tmpdir"
}

install_rancher_cli() {
    if ! command -v go &>/dev/null; then
        log INFO "Installing Go"
        NIXPKGS_ALLOW_UNFREE=1 nix-env -iA nixpkgs.go
        export PATH="$HOME/.nix-profile/bin:$PATH"
    fi

    local version
    version=$(curl -sS "https://api.github.com/repos/rancher/cli/releases/latest" | grep -o '"tag_name": ".*"' | cut -d'"' -f4)
    log INFO "Building Rancher CLI ${version}"
    
    local tmpdir
    tmpdir=$(mktemp -d)
    (
        cd "$tmpdir"
        curl -sfL "https://github.com/rancher/cli/archive/refs/tags/${version}.tar.gz" -o rancher-cli.tar.gz
        tar xzf rancher-cli.tar.gz
        cd "cli-${version#v}"
        GO111MODULE=on CGO_ENABLED=0 GOARCH=arm64 go build -ldflags "-X main.VERSION=${version}" -o rancher
        mv rancher "$HOME/.local/bin/rancher"
        chmod +x "$HOME/.local/bin/rancher"
    )
    rm -rf "$tmpdir"
}

install_tools() {
    mkdir -p "$HOME/.local/bin"
    local tmpdir
    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' EXIT
    
    for tool in "${!TOOLS[@]}"; do
        IFS=: read -r repo pattern bin <<< "${TOOLS[$tool]}"
        if ! command -v "$bin" >/dev/null 2>&1; then
            log INFO "Installing $tool"
            version=$(curl -sS "https://api.github.com/repos/${repo}/releases/latest" | grep -o '"tag_name": ".*"' | cut -d'"' -f4)
            log INFO "Latest version: $version"
            url="https://github.com/${repo}/releases/download/${version}/${pattern/VERSION/${version#v}}"
            log INFO "Downloading from: $url"
            
            # Download the archive
            local archive="$tmpdir/${tool}.archive"
            if curl -sSL -o "$archive" "$url"; then
                log INFO "Download completed for ${tool}, attempting extraction"
                case "$url" in
                    *.tar.gz)
                        tar xvf "$archive" -C "$tmpdir" || {
                            log ERROR "Failed to extract $archive"
                            continue
                        }
                        # List contents after extraction
                        log INFO "Contents after extraction:"
                        ls -R "$tmpdir"
                        
                        # For Velero specifically, it's in a versioned subdirectory
                        if [ "$tool" = "velero" ]; then
                            mv "$tmpdir"/velero-v*/velero "$HOME/.local/bin/velero" || {
                                log ERROR "Failed to move velero binary"
                                continue
                            }
                        else
                            find "$tmpdir" -type f -name "$bin" -exec mv {} "$HOME/.local/bin/$bin" \;
                        fi
                        ;;
                    *.zip)
                        unzip -q "$archive" -d "$tmpdir" || {
                            log ERROR "Failed to extract $archive"
                            continue
                        }
                        find "$tmpdir" -type f -name "$bin" -exec mv {} "$HOME/.local/bin/$bin" \;
                        ;;
                esac
                
                chmod +x "$HOME/.local/bin/$bin"
                if [ -x "$HOME/.local/bin/$bin" ]; then
                    log INFO "Successfully installed $tool"
                else
                    log ERROR "Failed to make $tool executable"
                fi
            else
                log ERROR "Failed to download $url"
            fi
        else
            log INFO "$tool is already installed"
        fi
    done
    if ! command -v velero >/dev/null 2>&1; then
        install_velero
    fi
    if ! command -v vault >/dev/null 2>&1; then
        install_vault
    fi

    if ! command -v pluto >/dev/null 2>&1; then
        install_pluto
    fi

    if ! command -v argocd >/dev/null 2>&1; then
        install_argocd
    fi

    if ! command -v argo >/dev/null 2>&1; then
        install_argo
    fi

    if ! command -v rancher >/dev/null 2>&1; then
        install_rancher_cli
    fi
}

setup_nix() {
    [[ ! -f "$HOME/.nix-channels" ]] || [[ $(find "$HOME/.nix-channels" -mtime +1) ]] && {
        nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
        nix-channel --update
    }
}

update_paths() {
    local config
    for config in "$HOME/.bashrc" "$HOME/.zshrc"; do
        [[ -f "$config" ]] || continue
        grep -q 'export PATH="$HOME/.nix-profile/bin:$PATH"' "$config" || 
            echo 'export PATH="$HOME/.nix-profile/bin:$PATH"' >> "$config"
        grep -q 'export PATH="$HOME/.local/bin:$PATH"' "$config" ||
            echo 'export PATH="$HOME/.local/bin:$PATH"' >> "$config"
        grep -q 'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"' "$config" ||
            echo 'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"' >> "$config"
    done
    export PATH="$HOME/.nix-profile/bin:$HOME/.local/bin:$PATH"
}

setup_completions() {
    mkdir -p "$HOME/.zfunc"
    for cmd in kubectl helm argocd argo velero rancher pluto vault; do
        if command -v "$cmd" >/dev/null 2>&1; then
            "$cmd" completion zsh > "$HOME/.zfunc/_$cmd" 2>/dev/null || true
        fi
    done
}

main() {
    local start_time=$SECONDS
    
    log INFO "Starting setup"
    mkdir -p "${DIRS[@]}"
    
    # Set up XDG_CONFIG_HOME
    export XDG_CONFIG_HOME="$HOME"/.config
    mkdir -p "$XDG_CONFIG_HOME"
    mkdir -p "$XDG_CONFIG_HOME"/nixpkgs
    
    # Create symlinks for existing configurations
    ln -sf "$PWD/nvim" "$XDG_CONFIG_HOME"/nvim
    ln -sf "$PWD/.inputrc" "$HOME"/.inputrc
    ln -sf "$PWD/.tmux.conf" "$HOME"/.tmux.conf
    ln -sf "$PWD/config.nix" "$XDG_CONFIG_HOME"/nixpkgs/config.nix
    
    setup_nix
    NIXPKGS_ALLOW_UNFREE=1 TERM=dumb nix-env -iA nixpkgs.myPackages
    
    install_tools
    update_paths
    setup_completions
    
    [[ ! -d "$HOME/.zsh/pure" ]] &&
        git clone --depth 1 https://github.com/sindresorhus/pure.git "$HOME/.zsh/pure"
    
    if ! command -v kubectl-krew >/dev/null 2>&1; then
        (
            cd "$(mktemp -d)" || exit 1
            curl -fsSLO "https://github.com/kubernetes-sigs/krew/releases/latest/download/krew-linux_arm64.tar.gz"
            tar zxf "krew-linux_arm64.tar.gz"
            ./krew-linux_arm64 install krew

            # Add Krew to path temporarily for plugin installation
            export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
            kubectl krew install neat
            kubectl krew install image
        )
    fi
    
    touch "$HOME/.privaterc"
    log INFO "Setup completed in $((SECONDS - start_time)) seconds"
}

main
