#!/bin/bash

set -e

error_handler() {
  echo "Error occurred in script at line: $1"
  exit 1
}

trap 'error_handler ${LINENO}' ERR

verify_commands() {
  local max_attempts=3
  local commands=("$@")
  
  echo "Verifying commands: ${commands[*]}"
  which "${commands[@]}" 2>/dev/null || return 1
}

setup_nix() {
  if ! nix-channel --list | grep -q "^nixpkgs "; then
    nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
  fi
  
  nix-channel --update
  mkdir -p "$HOME/.config/nixpkgs"
  
  if [[ -f "$PWD/config.nix" ]]; then
    ln -sf "$PWD/config.nix" "$HOME/.config/nixpkgs/config.nix"
  else
    echo "Error: config.nix not found"
    exit 1
  fi
}

install_nix_packages() {
  export NIXPKGS_ALLOW_UNFREE=1
  export TERM=dumb

  # Install packages
  nix-env -iA nixpkgs.myPackages || {
    nix-channel --update
    nix-env -iA nixpkgs.myPackages
  }

  # Add Nix profile to PATH
  export PATH="$HOME/.nix-profile/bin:$PATH"
  
  # Add to shell config files
  echo 'export PATH="$HOME/.nix-profile/bin:$PATH"' >> "$HOME/.bashrc"
  [[ -f "$HOME/.zshrc" ]] && echo 'export PATH="$HOME/.nix-profile/bin:$PATH"' >> "$HOME/.zshrc"

  # Source profile if available
  if [ -f "$HOME/.nix-profile/etc/profile.d/nix.sh" ]; then
    . "$HOME/.nix-profile/etc/profile.d/nix.sh"
  fi

  echo "Updated PATH=$PATH"
  verify_commands kubectl helm || {
    echo "Required tools not found after installation"
    ls -l "$HOME/.nix-profile/bin/kubectl" "$HOME/.nix-profile/bin/helm" || true
    exit 1
  }
}

create_dirs() {
  local dirs=(
    "$HOME/.config"
    "$HOME/.config/nixpkgs"
    "$HOME/.zsh"
    "$HOME/.local/bin"
    "$HOME/.zfunc"
  )

  for dir in "${dirs[@]}"; do
    mkdir -p "$dir"
  done
}

create_symlinks() {
  local links=(
    "$PWD/nvim:$HOME/.config/nvim"
    "$PWD/config.nix:$HOME/.config/nixpkgs/config.nix"
  )
  
  [[ -f "$PWD/.inputrc" ]] && links+=("$PWD/.inputrc:$HOME/.inputrc")
  [[ -f "$PWD/.tmux.conf" ]] && links+=("$PWD/.tmux.conf:$HOME/.tmux.conf")

  for link in "${links[@]}"; do
    local source="${link%:*}"
    local target="${link#*:}"
    if [[ -e "$source" ]]; then
      ln -sf "$source" "$target"
    fi
  done
}

install_pure_prompt() {
  if [[ ! -d "$HOME/.zsh/pure" ]]; then
    # Configure git for non-interactive operation
    export GIT_TERMINAL_PROMPT=0
    export GIT_SSH_COMMAND="ssh -o BatchMode=yes"
    
    git clone -q https://github.com/sindresorhus/pure.git "$HOME/.zsh/pure" || {
      echo "Warning: Pure prompt installation failed"
      return 1
    }
  fi
}

install_krew() {
  (
    cd "$(mktemp -d)" || exit 1
    
    OS="$(uname | tr '[:upper:]' '[:lower:]')"
    ARCH="$(uname -m | sed -e 's/x86_64/amd64/' -e 's/\(arm\)\(64\)\?.*/\1\2/' -e 's/aarch64$/arm64/')"
    KREW="krew-${OS}_${ARCH}"
    
    curl -fsSLO "https://github.com/kubernetes-sigs/krew/releases/latest/download/${KREW}.tar.gz"
    tar zxvf "${KREW}.tar.gz"
    
    # Configure for non-interactive installation
    export KREW_NO_UPGRADE_CHECK=1
    
    ./"${KREW}" install krew
    
    export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
    
    # Add Krew to PATH in shell configs
    echo 'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"' >> "$HOME/.bashrc"
    [[ -f "$HOME/.zshrc" ]] && echo 'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"' >> "$HOME/.zshrc"
    
    kubectl krew install neat
    kubectl krew install image
  ) || echo "Warning: Krew installation failed"
}

setup_completions() {
  mkdir -p "$HOME/.zfunc"
  kubectl completion zsh > "$HOME/.zfunc/_kubectl"
  helm completion zsh > "$HOME/.zfunc/_helm"
}

main() {
  create_dirs
  setup_nix
  install_nix_packages
  create_symlinks
  install_pure_prompt
  install_krew
  setup_completions
  
  touch "$HOME/.privaterc"
}

main "$@"
