#!/bin/bash
set -euo pipefail
# Enable debug mode
[[ "${DEBUG:-false}" == "true" ]] && set -x

# Constants
readonly DIRS=("$HOME/.config" "$HOME/.local/bin")
readonly TOOLS=(
    "velero:vmware-tanzu/velero:velero-vVERSION-linux-arm64.tar.gz:velero"
    "vault:hashicorp/vault:vault_VERSION.zip:vault"
    "pluto:FairwindsOps/pluto:pluto_VERSION_linux_arm64.tar.gz:pluto"
    "argocd:argoproj/argo-cd:argocd-linux-arm64:argocd"
    "argo:argoproj/argo-workflows:argo-linux-arm64.gz:argo"
    "rancher:rancher/cli:cli-VERSION-linux-arm64.tar.gz:rancher"
)

log() { 
    local level="$1"
    local message="$2"
    printf '[%s] [%s] %s\n' "$(date +%T)" "$level" "$message" >&2
}

cleanup() {
    if [ -n "${TMPDIR:-}" ] && [ -d "$TMPDIR" ]; then
        rm -rf "$TMPDIR"
    fi
}
trap cleanup EXIT

download_file() {
    local url="$1" output="$2"
    log INFO "Downloading from: $url"
    curl -fsSL --retry 3 --retry-delay 2 -o "$output" "$url"
}

get_file_type() {
    local filename="$1"
    if [[ "$filename" == *.tar.gz ]]; then
        echo "tar.gz"
    elif [[ "$filename" == *.zip ]]; then
        echo "zip"
    elif [[ "$filename" == *.gz ]]; then
        echo "gz"
    else
        echo "unknown"
    fi
}

extract_archive() {
    local archive="$1" type="$2" extract_dir="$3"
    log INFO "Extracting $archive of type $type to $extract_dir"
    
    case "$type" in
        tar.gz) 
            tar xzf "$archive" -C "$extract_dir"
            ;;
        zip)
            unzip -q "$archive" -d "$extract_dir"
            ;;
        gz)
            local output_file="$extract_dir/$(basename "$archive" .gz)"
            gunzip -c "$archive" > "$output_file"
            chmod +x "$output_file"
            ;;
        *) log ERROR "Unsupported archive type: $type"; return 1 ;;
    esac
    
    # Log contents for debugging
    log INFO "Extracted contents:"
    find "$extract_dir" -type f -ls
}

get_latest_version() {
    local repo="$1"
    local version
    version=$(curl -sS "https://api.github.com/repos/$repo/releases/latest" | jq -r '.tag_name // empty')
    [[ -n "$version" ]] || { log ERROR "Failed to get version for $repo"; return 1; }
    log INFO "Latest version for $repo: $version"
    printf "%s" "${version#v}"
}

verify_binary() {
    local bin="$1" name="$2"
    
    [[ -x "$bin" ]] || { log ERROR "Binary $bin not executable"; return 1; }
    
    case "$name" in
        velero)
            [[ -x "$bin" ]] && return 0
            ;;
        argocd)
            if file "$bin" | grep -q "ARM aarch64"; then
                return 0
            else
                log ERROR "Invalid architecture for $name"
                return 1
            fi
            ;;
        *)
            if ! "$bin" version 2>/dev/null || ! "$bin" --version 2>/dev/null; then
                log ERROR "Failed to verify $name installation"
                return 1
            fi
            ;;
    esac
}

find_binary() {
    local extract_dir="$1" bin_name="$2"
    log INFO "Searching for binary $bin_name in $extract_dir"
    
    # First try exact name match
    local binary_path
    binary_path=$(find "$extract_dir" -type f -name "$bin_name" -exec readlink -f {} \; -print -quit)
    
    # If not found, try searching in subdirectories recursively
    if [[ -z "$binary_path" ]]; then
        binary_path=$(find "$extract_dir" -type f -iname "$bin_name" -exec readlink -f {} \; -print -quit)
    fi
    
    if [[ -z "$binary_path" ]]; then
        log ERROR "Binary not found after searching"
        return 1
    fi
    
    # Verify the binary exists and is a file
    if [[ ! -f "$binary_path" ]]; then
        log ERROR "Found path is not a valid file: $binary_path"
        return 1
    fi
    
    log INFO "Found binary at: $binary_path"
    echo "$binary_path"
}

install_tool() {
    local name="$1" repo="$2" pattern="$3" bin_name="$4"
    TMPDIR="$(mktemp -d)"
    log INFO "Installing $name"
    
    local version
    version=$(get_latest_version "$repo") || return 1
    
    # Construct URL
    local url="https://github.com/${repo}/releases/download/v${version}/${pattern/VERSION/${version}}"
    log INFO "Download URL: $url"
    
    local archive="$TMPDIR/$name.archive"
    local extract_dir="$TMPDIR/extract"
    mkdir -p "$extract_dir"
    
    # Download the file
    download_file "$url" "$archive" || return 1
    
    # Determine the file type and extract accordingly
    local file_type
    file_type=$(get_file_type "$url")
    extract_archive "$archive" "$file_type" "$extract_dir" || return 1
    
    # Find the binary
    local binary_path
    binary_path=$(find_binary "$extract_dir" "$bin_name") || return 1
    
    log INFO "Moving binary from $binary_path to $HOME/.local/bin/$bin_name"
    install -m 755 "$binary_path" "$HOME/.local/bin/$bin_name"
    verify_binary "$HOME/.local/bin/$bin_name" "$name"
}

main() {
    log INFO "Starting setup"
    mkdir -p "${DIRS[@]}"
    
    for tool_info in "${TOOLS[@]}"; do
        IFS=: read -r name repo pattern bin_name <<< "$tool_info"
        if [[ -x "$HOME/.local/bin/$bin_name" ]]; then
            log INFO "Binary $bin_name already installed"
        else
            install_tool "$name" "$repo" "$pattern" "$bin_name" || {
                log ERROR "Failed to install $name"
                return 1
            }
        fi
    done
    
    log INFO "Setup completed"
}

main
