#!/bin/bash

set -euo pipefail

# Global variables
readonly DIRS=(
    "$HOME/.config"
    "$HOME/.config/nixpkgs"
    "$HOME/.zsh"
    "$HOME/.local/bin"
    "$HOME/.zfunc"
    "$HOME/.krew/bin"
)

# Tool definitions
declare -A TOOLS=(
    ["velero"]="vmware-tanzu/velero:velero-vVERSION-linux-arm64.tar.gz:velero"
    ["vault"]="hashicorp/vault:vault_VERSION_linux_arm64.zip:vault"
    ["pluto"]="FairwindsOps/pluto:pluto_VERSION_linux_arm64.tar.gz:pluto"
)

log() {
    printf '[%s] [%s] %s\n' "$(date +%T)" "$1" "$2"
}

cleanup() {
    local dir_to_cleanup="$1"
    [[ -d "$dir_to_cleanup" ]] && rm -rf "$dir_to_cleanup"
}

download_and_verify() {
    local url="$1"
    local output="$2"
    local max_retries=3
    local retry_count=0

    while [[ $retry_count -lt $max_retries ]]; do
        if curl -sSL --retry 3 --retry-delay 2 -o "$output" "$url"; then
            return 0
        fi
        ((retry_count++))
        log WARN "Download failed, attempt $retry_count of $max_retries"
        sleep 2
    done
    return 1
}

install_binary() {
    local name="$1"
    local url="$2"
    local bin_name="$3"
    local tmpdir
    tmpdir=$(mktemp -d)
    local success=false

    log INFO "Installing $name from: $url"

    (
        cd "$tmpdir" || exit 1
        if download_and_verify "$url" "${name}.archive"; then
            case "$url" in
                *.tar.gz)
                    if tar xzf "${name}.archive"; then
                        if [[ "$name" == "velero" ]]; then
                            mv "velero-"*"/velero" "$HOME/.local/bin/velero"
                        else
                            find . -type f -name "$bin_name" -exec mv {} "$HOME/.local/bin/$bin_name" \;
                        fi
                        success=true
                    fi
                    ;;
                *.zip)
                    if unzip -q "${name}.archive"; then
                        find . -type f -name "$bin_name" -exec mv {} "$HOME/.local/bin/$bin_name" \;
                        success=true
                    fi
                    ;;
            esac

            if [[ "$success" == true ]]; then
                chmod +x "$HOME/.local/bin/$bin_name"
                if "$HOME/.local/bin/$bin_name" version >/dev/null 2>&1; then
                    log INFO "Successfully installed $name"
                    cleanup "$tmpdir"
                    return 0
                fi
            fi
        fi
    )
    
    cleanup "$tmpdir"
    log ERROR "Failed to install $name"
    return 1
}

get_latest_version() {
    local repo="$1"
    curl -sS "https://api.github.com/repos/${repo}/releases/latest" | 
        grep -o '"tag_name": ".*"' | cut -d'"' -f4
}

install_tools() {
    mkdir -p "$HOME/.local/bin"
    
    for tool in "${!TOOLS[@]}"; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            IFS=: read -r repo pattern bin_name <<< "${TOOLS[$tool]}"
            version=$(get_latest_version "$repo")
            [[ -z "$version" ]] && continue
            
            log INFO "Installing $tool ${version}"
            url="https://github.com/${repo}/releases/download/${version}/${pattern/VERSION/${version#v}}"
            install_binary "$tool" "$url" "$bin_name"
        else
            log INFO "$tool is already installed"
        fi
    done
}

setup_nix() {
    if [[ ! -f "$HOME/.nix-channels" ]] || [[ $(find "$HOME/.nix-channels" -mtime +1) ]]; then
        nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
        nix-channel --update
    fi
}

update_paths() {
    local path_entries=(
        'export PATH="$HOME/.nix-profile/bin:$PATH"'
        'export PATH="$HOME/.local/bin:$PATH"'
        'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"'
    )
    
    for config in "$HOME/.bashrc" "$HOME/.zshrc"; do
        [[ -f "$config" ]] || continue
        for entry in "${path_entries[@]}"; do
            grep -q "$entry" "$config" || echo "$entry" >> "$config"
        done
    done
    
    export PATH="$HOME/.nix-profile/bin:$HOME/.local/bin:$PATH"
}

setup_completions() {
    mkdir -p "$HOME/.zfunc"
    for cmd in kubectl helm argocd argo velero rancher pluto vault; do
        if command -v "$cmd" >/dev/null 2>&1; then
            "$cmd" completion zsh > "$HOME/.zfunc/_$cmd" 2>/dev/null || true
        fi
    done
}

setup_krew() {
    if ! command -v kubectl-krew >/dev/null 2>&1; then
        local tmpdir
        tmpdir=$(mktemp -d)
        (
            cd "$tmpdir" || exit 1
            curl -fsSLO "https://github.com/kubernetes-sigs/krew/releases/latest/download/krew-linux_arm64.tar.gz"
            tar zxf "krew-linux_arm64.tar.gz"
            ./krew-linux_arm64 install krew

            export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
            kubectl krew install neat
            kubectl krew install image
        )
        cleanup "$tmpdir"
    fi
}

main() {
    local start_time=$SECONDS
    
    log INFO "Starting setup"
    mkdir -p "${DIRS[@]}"
    
    # Set up XDG_CONFIG_HOME
    export XDG_CONFIG_HOME="$HOME/.config"
    mkdir -p "$XDG_CONFIG_HOME/nixpkgs"
    
    # Create symlinks
    ln -sf "$PWD/nvim" "$XDG_CONFIG_HOME/nvim"
    ln -sf "$PWD/.inputrc" "$HOME/.inputrc"
    ln -sf "$PWD/.tmux.conf" "$HOME/.tmux.conf"
    ln -sf "$PWD/config.nix" "$XDG_CONFIG_HOME/nixpkgs/config.nix"
    
    setup_nix
    NIXPKGS_ALLOW_UNFREE=1 TERM=dumb nix-env -iA nixpkgs.myPackages
    
    install_tools
    update_paths
    setup_completions
    
    [[ ! -d "$HOME/.zsh/pure" ]] &&
        git clone --depth 1 https://github.com/sindresorhus/pure.git "$HOME/.zsh/pure"
    
    setup_krew
    
    touch "$HOME/.privaterc"
    log INFO "Setup completed in $((SECONDS - start_time)) seconds"
}

main
