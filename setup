#!/bin/bash
set -euo pipefail
# Enable debug mode
[[ "${DEBUG:-false}" == "true" ]] && set -x

# Constants
readonly DIRS=("$HOME/.config" "$HOME/.local/bin")
readonly TOOLS=(
    "velero:vmware-tanzu/velero:velero-vVERSION-linux-arm64.tar.gz:velero"
    "vault:hashicorp/vault:vault_VERSION.zip:vault"
    "pluto:FairwindsOps/pluto:pluto_VERSION_linux_arm64.tar.gz:pluto"
    "argocd:argoproj/argo-cd:argocd-linux-arm64:argocd"
    "argo:argoproj/argo-workflows:argo-linux-arm64.gz:argo"
    "rancher:rancher/cli:cli-VERSION-linux-arm64.tar.gz:rancher"
)

log() { printf '[%s] [%s] %s\n' "$(date +%T)" "$1" "$2"; }

cleanup() {
    [[ -d "$TMPDIR" ]] && rm -rf "$TMPDIR"
}
trap cleanup EXIT

download_file() {
    local url="$1" output="$2"
    curl -fsSL --retry 3 --retry-delay 2 -o "$output" "$url"
}

extract_archive() {
    local archive="$1" type="$2" extract_dir="$3"
    case "$type" in
        tar.gz) tar xzf "$archive" -C "$extract_dir" ;;
        zip) unzip -q "$archive" -d "$extract_dir" ;;
        gz) gunzip -c "$archive" > "$extract_dir/$(basename "$archive" .gz)" && chmod +x "$extract_dir/$(basename "$archive" .gz)" ;;
        *) log ERROR "Unsupported archive type: $type"; return 1 ;;
    esac
}

get_latest_version() {
    curl -sS "https://api.github.com/repos/$1/releases/latest" | jq -r '.tag_name // empty'
}

verify_binary() {
    local bin="$1" name="$2"
    
    [[ -x "$bin" ]] || { log ERROR "Binary $bin not executable"; return 1; }
    
    # Special handling for different tools
    case "$name" in
        velero)
            # Just check if it's executable and exists, since version check needs k8s
            [[ -x "$bin" ]] && return 0
            ;;
        argocd)
            # For Go binaries, just check if executable and correct architecture
            if file "$bin" | grep -q "ARM aarch64"; then
                return 0
            else
                log ERROR "Invalid architecture for $name"
                return 1
            fi
            ;;
        *)
            # Default verification for other tools
            if ! "$bin" version 2>/dev/null || ! "$bin" --version 2>/dev/null; then
                log ERROR "Failed to verify $name installation"
                return 1
            fi
            ;;
    esac
}

install_tool() {
    local name="$1" repo="$2" pattern="$3" bin_name="$4"
    TMPDIR=$(mktemp -d)
    log INFO "Installing $name"
    local version=$(get_latest_version "$repo") || { log ERROR "Failed to get version for $name"; return 1; }
    local url="https://github.com/${repo}/releases/download/${version}/${pattern/VERSION/${version#v}}"
    
    if [[ "$url" == *.tar.gz || "$url" == *.zip || "$url" == *.gz ]]; then
        local archive="$TMPDIR/$name.archive"
        local extract_dir="$TMPDIR/extract"
        mkdir -p "$extract_dir"
        
        download_file "$url" "$archive" || return 1
        extract_archive "$archive" "${url##*.}" "$extract_dir" || return 1
        binary_path=$(find "$extract_dir" -type f -name "$bin_name" -print -quit)
    else
        binary_path="$TMPDIR/$bin_name"
        download_file "$url" "$binary_path" || return 1
        chmod +x "$binary_path"
    fi
    
    [[ -f "$binary_path" ]] || { log ERROR "Binary $bin_name not found"; return 1; }
    mv "$binary_path" "$HOME/.local/bin/$bin_name"
    verify_binary "$HOME/.local/bin/$bin_name" "$name"
}

main() {
    log INFO "Starting setup"
    mkdir -p "${DIRS[@]}"
    
    for tool_info in "${TOOLS[@]}"; do
        IFS=: read -r name repo pattern bin_name <<< "$tool_info"
        [[ -x "$HOME/.local/bin/$bin_name" ]] || install_tool "$name" "$repo" "$pattern" "$bin_name"
    done
    
    log INFO "Setup completed"
}

main
