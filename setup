#!/bin/bash

# Exit on error
set -e

# Function to handle errors
error_handler() {
  echo "Error occurred in script at line: $1"
  exit 1
}

trap 'error_handler ${LINENO}' ERR

# Function to wait for commands to be available
wait_for_commands() {
  local timeout=120  # 2 minutes timeout
  local interval=2   # Check every 2 seconds
  local commands=("$@")
  
  echo "Waiting for commands to be available: ${commands[*]}"
  
  for cmd in "${commands[@]}"; do
    local waited=0
    while ! command -v "$cmd" >/dev/null 2>&1; do
      if [ $waited -ge $timeout ]; then
        echo "Timeout waiting for $cmd to become available"
        return 1
      fi
      echo "Waiting for $cmd to become available... ($waited seconds)"
      sleep $interval
      waited=$((waited + interval))
    done
    echo "$cmd is now available"
  done
}

# Function to setup Nix channels and configuration
setup_nix() {
  echo "Setting up Nix environment..."
  
  # Ensure nixpkgs channel exists
  if ! nix-channel --list | grep -q "^nixpkgs "; then
    echo "Adding nixpkgs channel..."
    nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
  fi
  
  # Update channels
  echo "Updating Nix channels..."
  nix-channel --update
  
  # Ensure config directory exists
  mkdir -p "$HOME/.config/nixpkgs"
  
  # Link config file
  if [[ -f "$PWD/config.nix" ]]; then
    echo "Linking Nix configuration..."
    ln -sf "$PWD/config.nix" "$HOME/.config/nixpkgs/config.nix"
  else
    echo "Error: config.nix not found in current directory"
    exit 1
  fi
}

# Function to install Nix packages
install_nix_packages() {
  echo "Installing Nix packages..."
  # First try installing
  if ! nix-env -iA nixpkgs.myPackages; then
    echo "Initial package installation failed, updating channels and trying again..."
    nix-channel --update
    # Try again after update
    if ! nix-env -iA nixpkgs.myPackages; then
      echo "Package installation failed. Please check your config.nix"
      exit 1
    fi
  fi
}

# Function to create directories
create_dirs() {
  local dirs=(
    "$HOME/.config"
    "$HOME/.config/nixpkgs"
    "$HOME/.zsh"
    "$HOME/.local/bin"
    "$HOME/.zfunc"
  )

  echo "Creating required directories..."
  for dir in "${dirs[@]}"; do
    mkdir -p "$dir"
  done
}

# Function to create symlinks
create_symlinks() {
  echo "Creating symlinks..."
  local links=(
    "$PWD/nvim:$HOME/.config/nvim"
    "$PWD/config.nix:$HOME/.config/nixpkgs/config.nix"
  )
  
  # Optional configs - only create symlinks if files exist
  [[ -f "$PWD/.inputrc" ]] && links+=("$PWD/.inputrc:$HOME/.inputrc")
  [[ -f "$PWD/.tmux.conf" ]] && links+=("$PWD/.tmux.conf:$HOME/.tmux.conf")

  for link in "${links[@]}"; do
    local source="${link%:*}"
    local target="${link#*:}"
    if [[ -e "$source" ]]; then
      ln -sf "$source" "$target"
      echo "Created symlink: $target -> $source"
    else
      echo "Warning: Source file $source does not exist, skipping symlink creation"
    fi
  done
}

# Function to install Pure prompt
install_pure_prompt() {
  echo "Installing Pure prompt..."
  if [[ ! -d "$HOME/.zsh/pure" ]]; then
    git clone --quiet https://github.com/sindresorhus/pure.git "$HOME/.zsh/pure" || {
      echo "Warning: Failed to install Pure prompt"
      return 1
    }
  fi
}

# Function to install Krew
install_krew() {
  echo "Installing Krew and plugins..."
  (
    cd "$(mktemp -d)" || exit 1
    
    OS="$(uname | tr '[:upper:]' '[:lower:]')"
    ARCH="$(uname -m | sed -e 's/x86_64/amd64/' -e 's/\(arm\)\(64\)\?.*/\1\2/' -e 's/aarch64$/arm64/')"
    KREW="krew-${OS}_${ARCH}"
    
    echo "Downloading Krew..."
    curl -fsSLO "https://github.com/kubernetes-sigs/krew/releases/latest/download/${KREW}.tar.gz"
    tar zxvf "${KREW}.tar.gz"
    
    echo "Installing Krew..."
    ./"${KREW}" install krew
    
    # Add Krew to PATH for current session
    export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
    
    # Add to shell rc files for persistence
    echo 'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"' >> "$HOME/.bashrc"
    [[ -f "$HOME/.zshrc" ]] && echo 'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"' >> "$HOME/.zshrc"
    
    echo "Installing Krew plugins..."
    kubectl krew install neat
    kubectl krew install images
  ) || echo "Warning: Krew installation failed"
}

# Function to setup completions
setup_completions() {
  echo "Setting up shell completions..."
  mkdir -p "$HOME/.zfunc"
  
  kubectl completion zsh > "$HOME/.zfunc/_kubectl"
  helm completion zsh > "$HOME/.zfunc/_helm"
}

# Main execution
main() {
  echo "Starting setup..."
  
  # Wait for Nix to finish setting up
  echo "Waiting for initial Nix setup..."
  sleep 5
  
  create_dirs
  setup_nix
  install_nix_packages
  
  echo "Waiting for required tools to be available..."
  wait_for_commands kubectl helm || {
    echo "Failed to detect required tools. Please check your Nix configuration."
    exit 1
  }
  
  create_symlinks
  install_pure_prompt
  install_krew
  setup_completions
  
  # Create empty .privaterc to silence warnings
  touch "$HOME/.privaterc"
  
  echo "Setup completed successfully!"
}

# Run main function
main "$@"
