# Install Nix packages with proper PATH handling
install_nix_packages() {
    log INFO "Installing Nix packages from config.nix"
    
    export NIXPKGS_ALLOW_UNFREE=1
    export TERM=dumb

    # Install packages with retry mechanism
    local max_attempts=3
    local attempt=1
    local wait_time=5

    while (( attempt <= max_attempts )); do
        if nix-env -iA nixpkgs.myPackages; then
            break
        else
            log WARN "Attempt $attempt failed. Retrying in $wait_time seconds..."
            sleep $wait_time
            (( attempt++ ))
            (( wait_time *= 2 ))
            
            if (( attempt > max_attempts )); then
                log ERROR "Failed to install Nix packages after $max_attempts attempts"
                exit 1
            fi
            
            nix-channel --update
        fi
    done

    # Update PATH immediately
    export PATH="$HOME/.nix-profile/bin:$PATH"
    
    # Source Nix profile script if available
    local nix_profile_script="$HOME/.nix-profile/etc/profile.d/nix.sh"
    if [[ -f "$nix_profile_script" ]]; then
        # shellcheck disable=SC1090
        source "$nix_profile_script"
    fi

    # Update shell configuration files
    local path_export='export PATH="$HOME/.nix-profile/bin:$PATH"'
    local shell_configs=("$HOME/.bashrc")
    [[ -f "$HOME/.zshrc" ]] && shell_configs+=("$HOME/.zshrc")

    for config in "${shell_configs[@]}"; do
        if ! grep -q "$path_export" "$config" 2>/dev/null; then
            echo "$path_export" >> "$config"
        fi
    done

    # Give the system a moment to register the new binaries
    sleep 1

    # Now verify the installation
    verify_commands "${REQUIRED_COMMANDS[@]}" || {
        log ERROR "Critical packages not installed correctly"
        # Instead of exiting, let's provide more diagnostic information
        log INFO "Current PATH: $PATH"
        log INFO "Contents of ~/.nix-profile/bin:"
        ls -l "$HOME/.nix-profile/bin" || true
        exit 1
    }
}

# Main execution function with corrected order
main() {
    local start_time
    start_time=$(date +%s)
    
    log INFO "Starting development environment setup"
    
    # Create all required directories first
    mkdir -p "${CONFIG_DIRS[@]}"
    
    # Setup Nix first and wait for it
    setup_nix
    
    # Install Nix packages and ensure PATH is updated
    install_nix_packages
    
    # Only after Nix packages are properly installed and PATH is updated,
    # proceed with other tasks that might depend on installed commands
    install_pure_prompt &
    
    # Wait for background tasks
    wait
    
    # Now run the rest of the setup
    create_symlinks
    install_krew
    setup_completions
    
    touch "$HOME/.privaterc"
    
    local end_time
    end_time=$(date +%s)
    local duration=$((end_time - start_time))
    
    log INFO "Setup completed successfully in $duration seconds"
}
