#!/bin/bash

set -euo pipefail

# Enable debug mode for more detailed output
if [[ "${DEBUG:-false}" == "true" ]]; then
    set -x
fi

# Global variables
readonly DIRS=(
    "$HOME/.config"
    "$HOME/.config/nixpkgs"
    "$HOME/.zsh"
    "$HOME/.local/bin"
    "$HOME/.zfunc"
    "$HOME/.krew/bin"
)

# Tool definitions with explicit versions
declare -A TOOLS=(
    ["velero"]="vmware-tanzu/velero:v1.15.2:velero-vVERSION-linux-arm64.tar.gz:velero"
    ["vault"]="hashicorp/vault:v1.13.0:vault_VERSION_linux_arm64.zip:vault"
    ["pluto"]="FairwindsOps/pluto:v5.16.1:pluto_VERSION_linux_arm64.tar.gz:pluto"
)

log() {
    printf '[%s] [%s] %s\n' "$(date +%T)" "$1" "$2"
}

debug_log() {
    if [[ "${DEBUG:-false}" == "true" ]]; then
        log "DEBUG" "$1"
    fi
}

cleanup() {
    local dir_to_cleanup="$1"
    if [[ -d "$dir_to_cleanup" ]]; then
        debug_log "Cleaning up directory: $dir_to_cleanup"
        rm -rf "$dir_to_cleanup"
    fi
}

verify_binary() {
    local bin_path="$1"
    local name="$2"

    if [[ ! -f "$bin_path" ]]; then
        log ERROR "Binary not found at $bin_path"
        return 1
    fi

    if [[ ! -x "$bin_path" ]]; then
        log ERROR "Binary $bin_path is not executable"
        return 1
    fi

    # Try to run version check
    if ! "$bin_path" version >/dev/null 2>&1; then
        log ERROR "Failed to verify $name installation - version check failed"
        return 1
    fi

    return 0
}

download_file() {
    local url="$1"
    local output="$2"
    local max_retries=3
    local retry_count=0

    while [[ $retry_count -lt $max_retries ]]; do
        debug_log "Attempting download: $url (attempt $((retry_count + 1)))"
        if curl -fsSL --retry 3 --retry-delay 2 -o "$output" "$url"; then
            debug_log "Download successful: $url"
            return 0
        fi
        ((retry_count++))
        log WARN "Download failed, attempt $retry_count of $max_retries"
        sleep 2
    done
    
    log ERROR "Failed to download after $max_retries attempts: $url"
    return 1
}

extract_archive() {
    local archive="$1"
    local type="$2"
    local extract_dir="$3"

    case "$type" in
        tar.gz)
            debug_log "Extracting tar.gz archive: $archive"
            tar xzf "$archive" -C "$extract_dir"
            ;;
        zip)
            debug_log "Extracting zip archive: $archive"
            unzip -q "$archive" -d "$extract_dir"
            ;;
        *)
            log ERROR "Unsupported archive type: $type"
            return 1
            ;;
    esac

    local extract_status=$?
    if [[ $extract_status -ne 0 ]]; then
        log ERROR "Failed to extract archive: $archive"
        return 1
    fi

    return 0
}

install_tool() {
    local name="$1"
    local repo="$2"
    local version="$3"
    local pattern="$4"
    local bin_name="$5"
    local tmpdir
    
    tmpdir=$(mktemp -d)
    trap 'cleanup "$tmpdir"' EXIT

    log INFO "Installing $name $version"
    
    # Construct download URL
    local url="https://github.com/${repo}/releases/download/${version}/${pattern/VERSION/${version#v}}"
    debug_log "Download URL: $url"

    # Create temporary directory for extraction
    local extract_dir="$tmpdir/extract"
    mkdir -p "$extract_dir"

    # Download the archive
    local archive_path="$tmpdir/${name}.archive"
    if ! download_file "$url" "$archive_path"; then
        return 1
    fi

    # Determine archive type and extract
    local archive_type
    if [[ $url == *.tar.gz ]]; then
        archive_type="tar.gz"
    elif [[ $url == *.zip ]]; then
        archive_type="zip"
    else
        log ERROR "Unsupported archive format: $url"
        return 1
    fi

    if ! extract_archive "$archive_path" "$archive_type" "$extract_dir"; then
        return 1
    fi

    # Install binary
    debug_log "Looking for binary: $bin_name in $extract_dir"
    if [[ "$name" == "velero" ]]; then
        # Special handling for Velero
        local velero_dir
        velero_dir=$(find "$extract_dir" -type d -name "velero-v*" -print -quit)
        if [[ -z "$velero_dir" ]]; then
            log ERROR "Could not find Velero directory in extracted archive"
            return 1
        fi
        debug_log "Found Velero directory: $velero_dir"
        cp "$velero_dir/velero" "$HOME/.local/bin/velero"
    else
        # Generic binary installation
        local binary_path
        binary_path=$(find "$extract_dir" -type f -name "$bin_name" -print -quit)
        if [[ -z "$binary_path" ]]; then
            log ERROR "Could not find binary $bin_name in extracted archive"
            return 1
        fi
        cp "$binary_path" "$HOME/.local/bin/$bin_name"
    fi

    chmod +x "$HOME/.local/bin/$bin_name"
    
    if verify_binary "$HOME/.local/bin/$bin_name" "$name"; then
        log INFO "Successfully installed $name $version"
        return 0
    else
        return 1
    fi
}

install_tools() {
    mkdir -p "$HOME/.local/bin"
    
    for tool in "${!TOOLS[@]}"; do
        if ! command -v "$tool" >/dev/null 2>&1; then
            IFS=: read -r repo version pattern bin_name <<< "${TOOLS[$tool]}"
            if ! install_tool "$tool" "$repo" "$version" "$pattern" "$bin_name"; then
                log ERROR "Failed to install $tool"
                return 1
            fi
        else
            log INFO "$tool is already installed"
        fi
    done
}

setup_nix() {
    if [[ ! -f "$HOME/.nix-channels" ]] || [[ $(find "$HOME/.nix-channels" -mtime +1) ]]; then
        nix-channel --add https://nixos.org/channels/nixpkgs-unstable nixpkgs
        nix-channel --update
    fi
}

update_paths() {
    local path_entries=(
        'export PATH="$HOME/.nix-profile/bin:$PATH"'
        'export PATH="$HOME/.local/bin:$PATH"'
        'export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"'
    )
    
    for config in "$HOME/.bashrc" "$HOME/.zshrc"; do
        [[ -f "$config" ]] || continue
        for entry in "${path_entries[@]}"; do
            grep -q "$entry" "$config" || echo "$entry" >> "$config"
        done
    done
    
    export PATH="$HOME/.nix-profile/bin:$HOME/.local/bin:$PATH"
}

setup_completions() {
    mkdir -p "$HOME/.zfunc"
    for cmd in kubectl helm argocd argo velero rancher pluto vault; do
        if command -v "$cmd" >/dev/null 2>&1; then
            "$cmd" completion zsh > "$HOME/.zfunc/_$cmd" 2>/dev/null || true
        fi
    done
}

setup_krew() {
    if ! command -v kubectl-krew >/dev/null 2>&1; then
        local tmpdir
        tmpdir=$(mktemp -d)
        trap 'cleanup "$tmpdir"' EXIT
        
        (
            cd "$tmpdir" || exit 1
            if ! download_file "https://github.com/kubernetes-sigs/krew/releases/latest/download/krew-linux_arm64.tar.gz" "krew.tar.gz"; then
                return 1
            fi
            tar zxf "krew.tar.gz"
            ./krew-linux_arm64 install krew

            export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
            kubectl krew install neat
            kubectl krew install image
        )
    fi
}

main() {
    local start_time=$SECONDS
    
    log INFO "Starting setup"
    mkdir -p "${DIRS[@]}"
    
    # Set up XDG_CONFIG_HOME
    export XDG_CONFIG_HOME="$HOME/.config"
    mkdir -p "$XDG_CONFIG_HOME/nixpkgs"
    
    # Create symlinks
    ln -sf "$PWD/nvim" "$XDG_CONFIG_HOME/nvim"
    ln -sf "$PWD/.inputrc" "$HOME/.inputrc"
    ln -sf "$PWD/.tmux.conf" "$HOME/.tmux.conf"
    ln -sf "$PWD/config.nix" "$XDG_CONFIG_HOME/nixpkgs/config.nix"
    
    setup_nix
    NIXPKGS_ALLOW_UNFREE=1 TERM=dumb nix-env -iA nixpkgs.myPackages
    
    if ! install_tools; then
        log ERROR "Tool installation failed"
        exit 1
    fi
    
    update_paths
    setup_completions
    
    if [[ ! -d "$HOME/.zsh/pure" ]]; then
        git clone --depth 1 https://github.com/sindresorhus/pure.git "$HOME/.zsh/pure"
    fi
    
    setup_krew
    
    touch "$HOME/.privaterc"
    log INFO "Setup completed in $((SECONDS - start_time)) seconds"
}

main
